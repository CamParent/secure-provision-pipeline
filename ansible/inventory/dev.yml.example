# PLACEHOLDER - this file is auto-generated by Terraform on `terraform apply`
# (see terraform/environments/dev/outputs.tf + inventory.tmpl).
# This copy exists only so the repo has a valid inventory to lint/test
# against before any VMs actually exist. Once you run terraform apply,
# this file gets overwritten with real IPs - do not edit by hand after that.

all:
  vars:
    ansible_user: ansible
    ansible_ssh_private_key_file: ~/.ssh/id_ed25519_ci
  children:
    bastion:
      hosts:
        bastion01:
          ansible_host: 192.168.1.60
    web:
      hosts:
        web01:
          ansible_host: 192.168.1.61
    db:
      hosts:
        db01:
          ansible_host: 192.168.1.62
